<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Robotico.Outbox</RootNamespace>
    <AssemblyName>Robotico.Outbox</AssemblyName>
    <PackageIcon>logosquare.png</PackageIcon>
    <PackageProjectUrl>https://github.com/robotico-dev/robotico-outbox-csharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/robotico-dev/robotico-outbox-csharp</RepositoryUrl>
    <RepositoryBranch>main</RepositoryBranch>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
    <!-- Package icon: single source at repo assets. -->
    <None Include="..\..\assets\logosquare.png" Pack="true" PackagePath="\" Link="logosquare.png" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup Condition="'$(UseLocalRoboticoResult)' != 'true'">
    <PackageReference Include="Robotico.Result" />
  </ItemGroup>
  <ItemGroup Condition="'$(UseLocalRoboticoResult)' == 'true'">
    <ProjectReference Include="$(RoboticoResultPath)" />
  </ItemGroup>
</Project>
